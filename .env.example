# ─── Nexus CV — Environment Configuration ───
# Copy this file to .env and fill in your API keys.
# At minimum, set GEMINI_API_KEY or GROQ_API_KEY for AI features.

# ── Flask ──
SECRET_KEY=generate-a-random-secret-key-here
FLASK_ENV=development

# ── LLM API Keys (at least one required for AI features) ──
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Optional LLM Providers (fallback chain) ──
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# ── n8n Integration ──
NEXUS_API_KEY=your_nexus_api_key_here

# ── OAuth (optional — for Google/Microsoft login) ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# ── Email (optional — for auto-emailing reports) ──
SENDGRID_API_KEY=your_sendgrid_api_key_here
