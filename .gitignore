# ─── Nexus CV .gitignore ───

# Environment & Secrets
.env
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
build/
instance/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# Database
*.db
*.sqlite3

# Logs
logs/
*.log

# Uploads & Reports (user-generated, runtime)
uploads/
reports/
generated_reports/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node (if applicable)
node_modules/

# Archive (dev test files)
archive/

# Keep placeholder files in gitignored dirs
!uploads/.gitkeep
!reports/.gitkeep
!logs/.gitkeep
